generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  users       User[]

  @@map("roles")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String?
  password     String
  phone        String?
  role_id      Int?
  bank_account String?
  created_at   DateTime  @default(now())
  role         Role?     @relation(fields: [role_id], references: [id])
  employee     Employee?

  @@map("users")
}

model Employee {
  id         Int            @id @default(autoincrement())
  user_id    Int            @unique
  position   String?
  start_date String?
  salary     Float?
  status     String         @default("active")
  created_at DateTime       @default(now())
  user       User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks      CeremonyTask[]
  payroll    Payroll[]
  advances   Advance[]

  @@map("employees")
}

model Ceremony {
  id            Int               @id @default(autoincrement())
  type          String?
  groom_name    String?
  bride_name    String?
  date_jalali   String?
  time          String?
  address       String?
  plan_details  String?
  total_amount  Float?
  advance_paid  Float?            @default(0)
  status        String            @default("booked")
  plan_id       Int?
  ceremony_mode String?           @default("quick")
  created_at    DateTime          @default(now())
  plan          Plan?             @relation(fields: [plan_id], references: [id])
  payments      CeremonyPayment[]
  tasks         CeremonyTask[]

  @@map("ceremonies")
}

model CeremonyPayment {
  id           Int      @id @default(autoincrement())
  ceremony_id  Int
  amount       Float?
  type         String?
  check_number String?
  due_date     String?
  status       String   @default("pending")
  created_at   DateTime @default(now())
  ceremony     Ceremony @relation(fields: [ceremony_id], references: [id], onDelete: Cascade)

  @@map("ceremony_payments")
}

model CeremonyTask {
  id               Int      @id @default(autoincrement())
  ceremony_id      Int
  employee_id      Int
  role_description String?
  attendance_hours Float?   @default(0)
  created_at       DateTime @default(now())
  ceremony         Ceremony @relation(fields: [ceremony_id], references: [id], onDelete: Cascade)
  employee         Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("ceremony_tasks")
}

model Plan {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  price       Float?     @default(0)
  features    String     @default("[]")
  is_active   Int        @default(1)
  created_at  DateTime   @default(now())
  ceremonies  Ceremony[]

  @@map("plans")
}

model Payroll {
  id           Int      @id @default(autoincrement())
  employee_id  Int
  month_year   String?
  gross_salary Float?
  deductions   Float?
  total        Float?
  pdf_path     String?
  status       String   @default("pending")
  created_at   DateTime @default(now())
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("payroll")
}

model Advance {
  id           Int      @id @default(autoincrement())
  employee_id  Int
  amount       Float?
  date_jalali  String?
  reason       String?
  status       String   @default("pending")
  created_at   DateTime @default(now())
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("advances")
}

model Expense {
  id          Int      @id @default(autoincrement())
  category    String?
  amount      Float?
  date_jalali String?
  description String?
  notes       String?
  created_at  DateTime @default(now())

  @@map("expenses")
}

model Settings {
  id            Int      @id @default(autoincrement())
  company_name  String   @default("آتلیه معین")
  about_us      String?
  contact_email String?
  contact_phone String?
  address       String?
  logo          String?
  updated_at    DateTime @updatedAt

  @@map("settings")
}
