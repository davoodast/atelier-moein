generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(false)
  created_at      DateTime         @default(now())
  users           User[]
  rolePermissions RolePermission[]
  ceremonyAssignments CeremonyAssignment[]

  @@map("roles")
}

model Permission {
  id          Int    @id @default(autoincrement())
  key         String @unique
  label_fa    String
  group       String
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String?
  password     String
  phone        String?
  role_id      Int?
  bank_account String?
  created_at   DateTime  @default(now())
  role         Role?     @relation(fields: [role_id], references: [id])
  employee     Employee?
  ceremonyAssignments CeremonyAssignment[]
  inboxMessages InboxMessage[]

  @@map("users")
}

model Employee {
  id               Int            @id @default(autoincrement())
  user_id          Int            @unique
  position         String?
  start_date       String?
  salary           Float?
  status           String         @default("active")
  work_description String?
  work_hours       Float?         @default(8)
  attendance_hours Float?         @default(0)
  created_at       DateTime       @default(now())
  user             User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks            CeremonyTask[]
  payroll          Payroll[]
  advances         Advance[]
  daily_todos      DailyTodo[]
  recurring_tasks  RecurringTask[]
  task_logs        TaskLog[]

  @@map("employees")
}

model Ceremony {
  id            Int               @id @default(autoincrement())
  type          String?
  groom_name    String?
  bride_name    String?
  date_jalali   String?
  time          String?
  address       String?
  plan_details  String?
  total_amount  Float?
  advance_paid  Float?            @default(0)
  status        String            @default("booked")
  plan_id       Int?
  ceremony_mode String?           @default("quick")
  created_at    DateTime          @default(now())
  plan          Plan?             @relation(fields: [plan_id], references: [id])
  payments      CeremonyPayment[]
  tasks         CeremonyTask[]
  assignments   CeremonyAssignment[]
  todos         CeremonyTodo[]

  @@map("ceremonies")
}

model CeremonyAssignment {
  id         Int      @id @default(autoincrement())
  ceremonyId Int
  userId     Int
  roleId     Int
  baseFee    Float?
  assignedAt DateTime @default(now())
  status     String   @default("active")

  ceremony   Ceremony @relation(fields: [ceremonyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])
  todos      CeremonyTodo[]

  @@unique([ceremonyId, userId])
  @@map("ceremony_assignments")
}

model CeremonyPayment {
  id           Int      @id @default(autoincrement())
  ceremony_id  Int
  amount       Float?
  type         String?
  check_number String?
  due_date     String?
  status       String   @default("pending")
  created_at   DateTime @default(now())
  ceremony     Ceremony @relation(fields: [ceremony_id], references: [id], onDelete: Cascade)

  @@map("ceremony_payments")
}

model CeremonyTask {
  id               Int      @id @default(autoincrement())
  ceremony_id      Int
  employee_id      Int
  role_description String?
  attendance_hours Float?   @default(0)
  created_at       DateTime @default(now())
  ceremony         Ceremony @relation(fields: [ceremony_id], references: [id], onDelete: Cascade)
  employee         Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("ceremony_tasks")
}

model Plan {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  price       Float?     @default(0)
  features    String     @default("[]")
  is_active   Int        @default(1)
  created_at  DateTime   @default(now())
  ceremonies  Ceremony[]

  @@map("plans")
}

model Payroll {
  id           Int      @id @default(autoincrement())
  employee_id  Int
  month_year   String?
  gross_salary Float?
  deductions   Float?
  total        Float?
  pdf_path     String?
  status       String   @default("pending")
  created_at   DateTime @default(now())
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("payroll")
}

model Advance {
  id           Int      @id @default(autoincrement())
  employee_id  Int
  amount       Float?
  date_jalali  String?
  reason       String?
  status       String   @default("pending")
  created_at   DateTime @default(now())
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("advances")
}

model Expense {
  id          Int      @id @default(autoincrement())
  category    String?
  amount      Float?
  date_jalali String?
  description String?
  notes       String?
  created_at  DateTime @default(now())

  @@map("expenses")
}

model Settings {
  id            Int      @id @default(autoincrement())
  company_name  String   @default("آتلیه معین")
  about_us      String?
  contact_email String?
  contact_phone String?
  address       String?
  logo          String?
  updated_at    DateTime @updatedAt

  @@map("settings")
}

model DailyTodo {
  id          Int      @id @default(autoincrement())
  employee_id Int
  date_jalali String
  title       String
  is_done     Boolean  @default(false)
  created_at  DateTime @default(now())
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("daily_todos")
}

model RecurringTask {
  id           Int       @id @default(autoincrement())
  employee_id  Int
  title        String
  description  String?
  interval     String    @default("weekly") // daily, weekly, monthly
  day_of_week  Int?      // 0=Sat,1=Sun,2=Mon,3=Tue,4=Wed,5=Thu,6=Fri
  day_of_month Int?      // 1-31 for monthly
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  employee     Employee  @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  logs         TaskLog[]

  @@map("recurring_tasks")
}

model TaskLog {
  id                Int            @id @default(autoincrement())
  employee_id       Int
  recurring_task_id Int?
  title             String
  date_jalali       String
  is_done           Boolean        @default(true)
  delete_requested  Boolean        @default(false)
  delete_reason     String?
  admin_approved    Int?           // null=pending, 1=approved, 0=rejected
  note              String?
  created_at        DateTime       @default(now())
  employee          Employee       @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  recurring_task    RecurringTask? @relation(fields: [recurring_task_id], references: [id], onDelete: SetNull)

  @@map("task_logs")
}

model CeremonyTodo {
  id            Int      @id @default(autoincrement())
  ceremonyId    Int
  assignmentId  Int
  title         String
  description   String?
  status        String   @default("pending") // pending, done, approved, rejected
  dueAt         DateTime?
  doneAt        DateTime?
  priority      Int      @default(1)
  penaltyPoints Int      @default(0)
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ceremony    Ceremony           @relation(fields: [ceremonyId], references: [id], onDelete: Cascade)
  assignment  CeremonyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("ceremony_todos")
}

model InboxMessage {
  id           Int      @id @default(autoincrement())
  senderUserId Int
  body         String
  status       String   @default("unread") // unread, read, replied
  adminReply   String?
  createdAt    DateTime @default(now())
  readAt       DateTime?
  repliedAt    DateTime?

  sender User @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@map("inbox_messages")
}
